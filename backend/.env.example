# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=inventory_db

# Full connection URL used by Prisma CLI (db push / migrate)
# URL-encode special characters in password (e.g. @ → %40)
# For TiDB Cloud / remote hosts, append: ?sslaccept=strict
DATABASE_URL="mysql://your_db_user:your_db_password@localhost:3306/inventory_db"

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=your_strong_random_secret_key

# ─── CORS ─────────────────────────────────────────────────
# Local dev:   http://localhost:5173
# Production:  https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
